---
// Phase 1-A: 各セクションを src/components/*.astro へ抽出済み
import Layout from '../layouts/Layout.astro';
import CTA from '../components/CTA.astro';
import CaseStudies from '../components/CaseStudies.astro';
import CommandPalette from '../components/CommandPalette.astro';
import CoreTech from '../components/CoreTech.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import Impact from '../components/Impact.astro';
import InkFilter from '../components/InkFilter.astro';
import Labs from '../components/Labs.astro';
import Modal from '../components/Modal.astro';
import Philosophy from '../components/Philosophy.astro';
---

<Layout>
  <div class="scroll-progress" aria-hidden="true"></div>
  <div class="custom-cursor" id="custom-cursor"></div>

  <InkFilter />

  <canvas
    id="ink-fx"
    style="position:fixed;top:0;left:0;width:100%;height:100%;z-index:2;pointer-events:none"
  ></canvas>
  <canvas id="tech-canvas"></canvas>
  <canvas
    id="particles-canvas"
    style="position:fixed;top:0;left:0;width:100%;height:100%;z-index:0;pointer-events:none"
  ></canvas>
  <canvas
    id="hero-ripple-canvas"
    aria-hidden="true"
    style="position:absolute;top:0;left:0;z-index:1;pointer-events:none;mix-blend-mode:multiply"
  ></canvas>
  <canvas
    id="trail-canvas"
    aria-hidden="true"
    style="position:fixed;top:0;left:0;width:100%;height:100%;z-index:9997;pointer-events:none"
  ></canvas>

  <header transition:name="site-header">
    <div
      class="logo"
      onclick="window.scrollTo({top:0, behavior:'smooth'})"
      transition:name="brand-logo"
    >ON TIME</div>
    <button
      id="ambient-toggle"
      class="ambient-btn"
      type="button"
      aria-label="環境音を再生"
      aria-pressed="false"
    >
      <span class="speaker-icon">🔇</span>
    </button>
  </header>

  <div class="container">
    <Hero />
    <Philosophy />
  </div>

  <Impact />
  <CoreTech />
  <CaseStudies />
  <Labs />
  <CTA />
  <Modal />
  <CommandPalette />
  <Footer />
</Layout>

<script>
  import '../scripts/main';
</script>
