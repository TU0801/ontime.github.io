---
// Phase 0-4 Step 1: 既存 index.html の <body> 内容を丸ごと Layout にマウント
// 後続タスクで各セクションを src/components/*.astro に抽出予定
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div class="scroll-progress" aria-hidden="true"></div>
  <div class="custom-cursor" id="custom-cursor"></div>
  <div class="cursor-trail" id="cursor-trail"></div>

  {/* SVG Ink Filters */}
  <svg style="position:absolute;width:0;height:0" aria-hidden="true">
    <defs>
      <filter id="ink-filter" x="-5%" y="-5%" width="110%" height="110%">
        <feTurbulence type="fractalNoise" baseFrequency="0.04" numOctaves="4" seed="2" result="noise"/>
        <feDisplacementMap in="SourceGraphic" in2="noise" scale="3" xChannelSelector="R" yChannelSelector="G" result="displaced"/>
        <feMorphology in="displaced" operator="dilate" radius="0.3" result="thickened"/>
        <feGaussianBlur in="thickened" stdDeviation="0.4" result="blurred"/>
        <feComponentTransfer in="blurred" result="sharpened">
          <feFuncA type="discrete" tableValues="0 1"/>
        </feComponentTransfer>
        <feTurbulence type="fractalNoise" baseFrequency="0.08" numOctaves="3" seed="7" result="edgeNoise"/>
        <feDisplacementMap in="sharpened" in2="edgeNoise" scale="1.5" result="roughEdge"/>
        <feComposite in="SourceGraphic" in2="roughEdge" operator="in"/>
      </filter>
    </defs>
  </svg>

  <canvas id="ink-fx" style="position:fixed;top:0;left:0;width:100%;height:100%;z-index:2;pointer-events:none"></canvas>
  <canvas id="tech-canvas"></canvas>

  <header>
    <div class="logo" onclick="window.scrollTo({top:0, behavior:'smooth'})">ON TIME</div>
  </header>

  <div class="container">
    <section class="hero">
      <div class="hero-content">
        <p class="hero-eyebrow">Advanced Efficiency Solutions</p>
        <h1 class="gradient-text-hero hero-title" aria-label="残業を過去にする。">
          <span class="char-line"><span class="char" style="--i:0">残</span><span class="char" style="--i:1">業</span><span class="char" style="--i:2">を</span></span><br>
          <span class="char-line"><span class="char" style="--i:3">過</span><span class="char" style="--i:4">去</span><span class="char" style="--i:5">に</span><span class="char" style="--i:6">す</span><span class="char" style="--i:7">る</span><span class="char" style="--i:8">。</span></span>
        </h1>
        <h2 class="hero-subtitle">
          <span class="word" style="--i:0">Time</span>
          <span class="word" style="--i:1">is</span>
          <span class="word" style="--i:2">your</span>
          <span class="word" style="--i:3">asset.</span>
        </h2>
        <a href="/check" class="cta-btn">課題を診断する →</a>
      </div>
    </section>

    <section class="philosophy section-hidden">
      <h3>PHILOSOPHY</h3>
      <div class="philosophy-text">
        <p class="philosophy-lead">
          時間は、人類にとって最も希少な資源です。
        </p>
        <p class="philosophy-body">
          しかし、多くのビジネスは旧態依然としたプロセスに時間を奪われています。
          私たちは、<span class="highlight">圧倒的な技術力</span>で、その非効率を徹底的に排除する。
        </p>
        <div class="philosophy-signature">
          <p class="philosophy-brand">ON TIME。</p>
          <p class="philosophy-closer">
            それは単なるツールではありません。<br>
            あなたが、本来向き合うべき創造的な仕事への回帰。<br>
            それが、私たちの提供する「未来」。
          </p>
        </div>
      </div>
    </section>
  </div>

  <section class="impact-numbers section-hidden">
    <div class="container">
      <h3>RESULTS</h3>
      <div class="metrics-grid">
        <div class="metric-card">
          <span class="metric-number gradient-text-hero" data-target="2000" data-suffix="+">0</span>
          <span class="metric-unit">hours</span>
          <span class="metric-label">削減された作業時間</span>
        </div>
        <div class="metric-card">
          <span class="metric-number gradient-text-hero" data-target="98" data-suffix="%">0</span>
          <span class="metric-unit">satisfaction</span>
          <span class="metric-label">クライアント満足度</span>
        </div>
        <div class="metric-card">
          <span class="metric-number gradient-text-hero" data-target="7" data-suffix="">0</span>
          <span class="metric-unit">technologies</span>
          <span class="metric-label">コアテクノロジー</span>
        </div>
        <div class="metric-card">
          <span class="metric-number gradient-text-hero" data-target="50" data-suffix="%">0</span>
          <span class="metric-unit">average</span>
          <span class="metric-label">平均効率改善率</span>
        </div>
      </div>
    </div>
  </section>

  <section class="tech-showcase section-hidden">
    <div class="container">
      <h3>CORE TECHNOLOGIES</h3>
      <div class="bento-grid">
        <div class="bento-card bento-wide" data-target="ai">
          <div class="bento-icon"><div class="geo-icon geo-ai"></div></div>
          <div class="bento-content">
            <h4 class="bento-title">AI Optimization</h4>
            <p class="bento-desc">AIが要件解析から書類生成まで一貫対応</p>
          </div>
          <span class="bento-arrow">→</span>
        </div>
        <div class="bento-card" data-target="cloud">
          <div class="bento-icon"><div class="geo-icon geo-cloud"></div></div>
          <div class="bento-content">
            <h4 class="bento-title">Cloud Native</h4>
            <p class="bento-desc">サーバーレスで高可用性を実現</p>
          </div>
          <span class="bento-arrow">→</span>
        </div>
        <div class="bento-card" data-target="workflow">
          <div class="bento-icon"><div class="geo-icon geo-workflow"></div></div>
          <div class="bento-content">
            <h4 class="bento-title">Automated Workflow</h4>
            <p class="bento-desc">手作業をBot + RPAで完全自動化</p>
          </div>
          <span class="bento-arrow">→</span>
        </div>
        <div class="bento-card" data-target="data">
          <div class="bento-icon"><div class="geo-icon geo-data"></div></div>
          <div class="bento-content">
            <h4 class="bento-title">Data Analytics</h4>
            <p class="bento-desc">リアルタイム計測でボトルネック特定</p>
          </div>
          <span class="bento-arrow">→</span>
        </div>
        <div class="bento-card bento-wide" data-target="scale">
          <div class="bento-icon"><div class="geo-icon geo-scale"></div></div>
          <div class="bento-content">
            <h4 class="bento-title">Scalability</h4>
            <p class="bento-desc">複数拠点からの同時アクセスに安定対応</p>
          </div>
          <span class="bento-arrow">→</span>
        </div>
        <div class="bento-card" data-target="security">
          <div class="bento-icon"><div class="geo-icon geo-security"></div></div>
          <div class="bento-content">
            <h4 class="bento-title">Security First</h4>
            <p class="bento-desc">機密書類をクラウドで安全に処理</p>
          </div>
          <span class="bento-arrow">→</span>
        </div>
        <div class="bento-card" data-target="realtime">
          <div class="bento-icon"><div class="geo-icon geo-realtime"></div></div>
          <div class="bento-content">
            <h4 class="bento-title">Real-time Processing</h4>
            <p class="bento-desc">双方向同期で情報のタイムラグ排除</p>
          </div>
          <span class="bento-arrow">→</span>
        </div>
      </div>
    </div>
  </section>

  <section class="case-studies section-hidden">
    <div class="container">
      <h3>CASE STUDIES</h3>
      <div class="case-preview-grid">
        <div class="case-preview" data-target="ai" style="--accent: #9D50BB;">
          <span class="case-preview-label">AI Optimization</span>
          <h4 class="case-preview-title">補助金申請業務の自動化</h4>
          <p class="case-preview-result">申請準備のリードタイムを大幅短縮</p>
          <span class="case-preview-link">詳細を見る →</span>
        </div>
        <div class="case-preview" data-target="workflow" style="--accent: #00C6FF;">
          <span class="case-preview-label">Automated Workflow</span>
          <h4 class="case-preview-title">定例作業の完全自動化</h4>
          <p class="case-preview-result">月次数時間の手作業をほぼゼロに圧縮</p>
          <span class="case-preview-link">詳細を見る →</span>
        </div>
        <div class="case-preview" data-target="data" style="--accent: #FF4B1F;">
          <span class="case-preview-label">Data Analytics</span>
          <h4 class="case-preview-title">製造工程の作業時間データ化</h4>
          <p class="case-preview-result">ボトルネック工程を特定し残業原因を解消</p>
          <span class="case-preview-link">詳細を見る →</span>
        </div>
      </div>
    </div>
  </section>

  <section class="pre-footer-cta">
    <div class="container">
      <h2 class="cta-heading gradient-text-hero">次のステップへ</h2>
      <p class="cta-sub">課題を診断して、最適なソリューションを見つけましょう。</p>
      <a href="/check" class="cta-btn cta-btn-light">課題を診断する →</a>
    </div>
  </section>

  <div class="modal-overlay" id="modal-overlay">
    <div class="modal-content">
      <span class="close-btn" id="modal-close">×</span>
      <div id="modal-body"></div>
    </div>
  </div>

  <div class="detail-source" id="content-ai">
    <h4 class="modal-title gradient-text">AI Optimization</h4>
    <p class="modal-desc">
      申請に必要な要件の解析から書類の自動生成まで、AIが一貫して担当します。担当者の膨大な調査・転記作業を大幅に削減し、申請精度を向上させます。
    </p>
    <div class="case-study">
      <span class="case-label">導入事例</span>
      <div class="case-title">補助金申請業務の自動化</div>
      <div class="case-text">
        補助金制度の改正ごとに調査・整理が必要だった担当者の作業。AIが最新の要件を自動解析し、申請書のドラフトを自動生成することで、担当者は内容の確認・承認に専念。申請準備のリードタイムを大幅に短縮しました。
      </div>
    </div>
  </div>

  <div class="detail-source" id="content-cloud">
    <h4 class="modal-title gradient-text">Cloud Native</h4>
    <p class="modal-desc">
      サーバーレス構成で、インフラ管理コストをゼロにしながら高可用性を実現。季節需要のピーク時にも自動でスケールアウトし、安定稼働を維持します。
    </p>
    <div class="case-study">
      <span class="case-label">導入事例</span>
      <div class="case-title">食材調達プラットフォームの構築</div>
      <div class="case-text">
        学期始めや給食メニュー改訂時に集中するアクセスで、旧システムが頻繁にダウン。サーバーレス構成へ刷新したことで、ピーク時のアクセスにも無停止で対応。インフラ保守の工数もゼロになりました。
      </div>
    </div>
  </div>

  <div class="detail-source" id="content-workflow">
    <h4 class="modal-title gradient-text">Automated Workflow</h4>
    <p class="modal-desc">
      チャットBot とRPAを組み合わせた構成で、手作業による登録・転記業務を完全自動化。担当者の月次作業をほぼゼロに圧縮します。
    </p>
    <div class="case-study">
      <span class="case-label">導入事例</span>
      <div class="case-title">定例作業の完全自動化</div>
      <div class="case-text">
        毎月、担当者が手作業で行っていた会議議案のWebシステムへの登録作業。チャットBotで議案情報を受け付け、RPAが自動的にシステムへ登録することで、月次数時間の作業がほぼゼロに。担当者の負担を劇的に軽減しました。
      </div>
    </div>
  </div>

  <div class="detail-source" id="content-data">
    <h4 class="modal-title gradient-text">Data Analytics</h4>
    <p class="modal-desc">
      各工程の作業時間をリアルタイム計測し、クラウドへ自動記録。属人的な「目安時間」を客観的データに変換し、ボトルネックの特定と改善サイクルを加速します。
    </p>
    <div class="case-study">
      <span class="case-label">導入事例</span>
      <div class="case-title">製造工程の作業時間データ化</div>
      <div class="case-text">
        「だいたい30分くらい」という経験則で管理されていた各製造工程の作業時間。工程タイマーで実測値を収集しクラウドへ自動記録することで、工程ごとの所要時間を数値化。生産計画の精度が向上し、残業の原因となっていたボトルネック工程を特定できました。
      </div>
    </div>
  </div>

  <div class="detail-source" id="content-scale">
    <h4 class="modal-title gradient-text">Scalability</h4>
    <p class="modal-desc">
      クラウド型の発注管理システムで、複数現場からの同時アクセスにも安定対応。発注状況の一元管理により、重複発注・発注漏れをゼロにします。
    </p>
    <div class="case-study">
      <span class="case-label">導入事例</span>
      <div class="case-title">複数拠点の発注一元管理</div>
      <div class="case-text">
        複数の建設現場から電話・FAXで寄せられる資材発注の管理が属人化し、重複発注や発注漏れが頻発。クラウドで発注状況を一元管理するシステムを構築したことで、複数現場からの同時アクセスに対応しながら、発注ミスをゼロに削減しました。
      </div>
    </div>
  </div>

  <div class="detail-source" id="content-security">
    <h4 class="modal-title gradient-text">Security First</h4>
    <p class="modal-desc">
      AIドキュメント解析とクラウドDBにより、機密性の高い紙書類をクラウド上で安全に処理・管理。入力ミス・紛失リスクをゼロにし、大手クライアントのセキュリティ要件にも対応します。
    </p>
    <div class="case-study">
      <span class="case-label">導入事例</span>
      <div class="case-title">紙書類のクラウド管理・デジタル化</div>
      <div class="case-text">
        紙の点検書類が担当者のデスクに積み上がり、必要なときに見つからない・転記ミスが起きる状況が続いていた。AIドキュメント解析でPDFを自動解析しクラウドDBに格納することで、書類の紛失・転記ミスをゼロ化。クラウド上での安全な保管・検索を実現しました。
      </div>
    </div>
  </div>

  <div class="detail-source" id="content-realtime">
    <h4 class="modal-title gradient-text">Real-time Processing</h4>
    <p class="modal-desc">
      リアルタイムDBにより、生産者と調達先の間で在庫・発注状況を双方向同期。情報のタイムラグを排除し、発注ミスや食材不足を防ぎます。
    </p>
    <div class="case-study">
      <span class="case-label">導入事例</span>
      <div class="case-title">生産者と調達先のリアルタイム連携</div>
      <div class="case-text">
        農家からの入荷情報と給食センターの発注状況が電話・FAX経由で伝わるため、タイムラグによる「発注したのに在庫がなかった」問題が頻発。リアルタイムDBを導入し、両者の在庫・発注データをリアルタイム同期することで、情報のずれをゼロにしました。
      </div>
    </div>
  </div>

  <footer>
    <div class="container">
      <div class="footer-grid">
        <div class="footer-left">
          <div class="footer-brand">ON TIME</div>
          <div class="footer-tagline">時間を、味方に。</div>
          <div class="notice">
            ※ 本サイトは、代表者が直接名刺交換をさせていただいた方へのご案内用です。<br>
            恐れ入りますが、直接のご面識のない方からのお問い合わせはご遠慮いただいております。
          </div>
        </div>
        <div class="footer-right">
          <div class="footer-nav-group">
            <span class="footer-nav-label">Service</span>
            <a href="/check" class="footer-nav-link">課題診断</a>
          </div>
          <div class="footer-nav-group">
            <span class="footer-nav-label">Technology</span>
            <span class="footer-nav-link">AI Optimization</span>
            <span class="footer-nav-link">Cloud Native</span>
            <span class="footer-nav-link">Automation</span>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <div class="copyright">© 2025 ON TIME. All Rights Reserved.</div>
      </div>
    </div>
  </footer>
</Layout>
