---
// 初回訪問時のみ走るブランド演出。localStorage に永続化して再訪では出ない。
// 2.8 秒の短いシーケンス: overlay → ロゴ登場 → タグライン → fade out。
// クリック / キー入力で即スキップ可能。
---

<div
  id="brand-reveal"
  class="brand-reveal"
  aria-hidden="true"
  role="presentation"
>
  <div class="brand-reveal__bar top"></div>
  <div class="brand-reveal__bar bottom"></div>
  <div class="brand-reveal__center">
    <div class="brand-reveal__brand">
      <span class="brand-reveal__char" style="--d: 0.0s">O</span>
      <span class="brand-reveal__char" style="--d: 0.06s">N</span>
      <span class="brand-reveal__char" style="--d: 0.16s">&nbsp;</span>
      <span class="brand-reveal__char" style="--d: 0.20s">T</span>
      <span class="brand-reveal__char" style="--d: 0.26s">I</span>
      <span class="brand-reveal__char" style="--d: 0.32s">M</span>
      <span class="brand-reveal__char" style="--d: 0.38s">E</span>
    </div>
    <div class="brand-reveal__divider" aria-hidden="true"></div>
    <div class="brand-reveal__tagline">Time is your asset.</div>
  </div>
</div>

<style is:global>
  .brand-reveal {
    position: fixed; inset: 0;
    z-index: 10001;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    background: #0F1115;
    pointer-events: auto;
    will-change: opacity;
    opacity: 1;
    transition: opacity 0.6s ease-out;
  }
  .brand-reveal.exiting {
    opacity: 0;
    pointer-events: none;
  }
  .brand-reveal.done { display: none; }

  /* 上下に走る金属的なバー（映画の幕みたいな） */
  .brand-reveal__bar {
    position: absolute; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent 0%, #5A7A94 15%, #1E3A5F 50%, #5A7A94 85%, transparent 100%);
    transform: scaleX(0);
    transform-origin: left;
    animation: brand-reveal-bar 1.1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: 0.1s;
    opacity: 0.9;
  }
  .brand-reveal__bar.top { top: 18vh; }
  .brand-reveal__bar.bottom { bottom: 18vh; transform-origin: right; animation-delay: 0.2s; }
  @keyframes brand-reveal-bar { from { transform: scaleX(0); } to { transform: scaleX(1); } }

  .brand-reveal__center {
    display: flex; flex-direction: column; align-items: center; gap: 20px;
    padding: 0 24px;
  }

  .brand-reveal__brand {
    display: flex;
    font-family: 'Montserrat Variable', 'Helvetica Neue', sans-serif;
    font-weight: 900;
    font-size: clamp(2rem, 6vw, 4rem);
    letter-spacing: 0.18em;
    color: #F4F3EE;
    text-shadow: 0 0 24px rgba(90, 122, 148, 0.25);
  }
  .brand-reveal__char {
    display: inline-block;
    opacity: 0;
    transform: translateY(18px);
    animation: brand-reveal-char 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: calc(0.5s + var(--d, 0s));
  }
  @keyframes brand-reveal-char {
    from { opacity: 0; transform: translateY(18px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .brand-reveal__divider {
    width: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, #5A7A94, transparent);
    animation: brand-reveal-divider 0.8s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: 1.2s;
    opacity: 0;
  }
  @keyframes brand-reveal-divider {
    from { opacity: 0; width: 0; }
    to { opacity: 1; width: 200px; }
  }

  .brand-reveal__tagline {
    font-family: var(--font-jp);
    font-size: clamp(0.9rem, 1.2vw, 1.1rem);
    color: #9CA0A7;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0;
    transform: translateY(8px);
    animation: brand-reveal-tagline 0.8s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: 1.5s;
  }
  @keyframes brand-reveal-tagline {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 0.92; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .brand-reveal { display: none !important; }
  }
</style>
