---
// Command palette (⌘K / Ctrl+K)
// Round 10 / Phase 18: power-user 向けの高速ナビゲーション
---

<div
  class="cmdk-overlay"
  id="cmdk-overlay"
  role="dialog"
  aria-modal="true"
  aria-label="コマンドパレット"
  aria-hidden="true"
>
  <div class="cmdk-panel" role="combobox" aria-haspopup="listbox" aria-expanded="false">
    <div class="cmdk-search">
      <svg class="cmdk-icon" viewBox="0 0 24 24" aria-hidden="true">
        <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2" fill="none"></circle>
        <path d="M20 20l-3.5-3.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
      </svg>
      <input
        type="text"
        id="cmdk-input"
        class="cmdk-input"
        placeholder="コマンドを検索…"
        autocomplete="off"
        spellcheck="false"
        aria-label="コマンド検索"
      />
      <kbd class="cmdk-kbd">ESC</kbd>
    </div>
    <ul class="cmdk-list" id="cmdk-list" role="listbox"></ul>
    <div class="cmdk-footer">
      <span><kbd>↑</kbd><kbd>↓</kbd> 移動</span>
      <span><kbd>↵</kbd> 決定</span>
      <span><kbd>⌘</kbd><kbd>K</kbd> 開閉</span>
    </div>
  </div>
</div>

<style is:global>
  .cmdk-overlay {
    position: fixed; inset: 0;
    background: rgba(15, 17, 21, 0.55);
    backdrop-filter: blur(14px) saturate(1.2);
    z-index: 200;
    display: flex; align-items: flex-start; justify-content: center;
    padding-top: 18vh;
    opacity: 0; pointer-events: none;
    transition: opacity 0.18s ease;
  }
  .cmdk-overlay.active { opacity: 1; pointer-events: auto; }

  .cmdk-panel {
    width: min(620px, 92vw);
    background: rgba(244, 243, 238, 0.98);
    border: 1px solid rgba(42, 42, 42, 0.08);
    border-radius: 14px;
    box-shadow: 0 22px 60px rgba(15, 17, 21, 0.45);
    transform: translateY(-8px) scale(0.97);
    opacity: 0;
    transition: transform 0.22s cubic-bezier(0.22,1,0.36,1), opacity 0.18s ease;
    overflow: hidden;
  }
  .cmdk-overlay.active .cmdk-panel { transform: translateY(0) scale(1); opacity: 1; }

  body.theme-dark .cmdk-panel {
    background: rgba(22, 25, 34, 0.98);
    border-color: rgba(232, 230, 225, 0.08);
  }

  .cmdk-search {
    display: flex; align-items: center; gap: 10px;
    padding: 14px 18px;
    border-bottom: 1px solid rgba(42, 42, 42, 0.08);
  }
  body.theme-dark .cmdk-search { border-bottom-color: rgba(232, 230, 225, 0.08); }

  .cmdk-icon {
    width: 18px; height: 18px;
    color: #6B6F76; flex-shrink: 0;
  }

  .cmdk-input {
    flex: 1;
    font: 500 0.95rem/1.4 'Montserrat Variable', 'Noto Sans JP Variable', sans-serif;
    color: inherit;
    background: transparent;
    border: none; outline: none;
    padding: 6px 0;
  }
  .cmdk-input::placeholder { color: rgba(107, 111, 118, 0.65); }

  .cmdk-kbd, .cmdk-footer kbd {
    font-family: 'Montserrat Variable', monospace;
    font-size: 0.68rem; font-weight: 700;
    letter-spacing: 0.06em;
    padding: 3px 8px;
    border: 1px solid rgba(42, 42, 42, 0.18);
    border-radius: 5px;
    background: rgba(255, 255, 255, 0.6);
    color: #6B6F76;
  }
  body.theme-dark .cmdk-kbd,
  body.theme-dark .cmdk-footer kbd {
    border-color: rgba(232, 230, 225, 0.12);
    background: rgba(20, 20, 20, 0.4);
    color: #9CA0A7;
  }

  .cmdk-list {
    list-style: none; max-height: 340px; overflow-y: auto;
    padding: 6px 0;
  }
  .cmdk-item {
    display: flex; align-items: center; gap: 14px;
    padding: 10px 18px;
    cursor: pointer;
    font-size: 0.92rem;
    color: #2A2A2A;
    transition: background 0.15s;
  }
  body.theme-dark .cmdk-item { color: #E8E6E1; }
  .cmdk-item.active {
    background: rgba(30, 58, 95, 0.08);
  }
  body.theme-dark .cmdk-item.active {
    background: rgba(90, 122, 148, 0.15);
  }
  .cmdk-item-icon {
    width: 26px; height: 26px;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.95rem;
    color: #1E3A5F;
    background: rgba(30, 58, 95, 0.08);
    border-radius: 6px;
    flex-shrink: 0;
  }
  body.theme-dark .cmdk-item-icon {
    color: #5A7A94;
    background: rgba(90, 122, 148, 0.15);
  }
  .cmdk-item-label { flex: 1; }
  .cmdk-item-hint {
    font-size: 0.72rem; color: #9CA0A7;
    letter-spacing: 0.05em;
  }
  .cmdk-empty {
    padding: 24px 18px; text-align: center; color: #9CA0A7;
    font-size: 0.88rem;
  }

  .cmdk-footer {
    display: flex; gap: 18px;
    padding: 10px 18px;
    border-top: 1px solid rgba(42, 42, 42, 0.08);
    font-size: 0.72rem; color: #9CA0A7;
  }
  body.theme-dark .cmdk-footer { border-top-color: rgba(232, 230, 225, 0.08); }
  .cmdk-footer span { display: flex; align-items: center; gap: 4px; }
  .cmdk-footer kbd { padding: 1px 6px; font-size: 0.62rem; }

  @media (prefers-reduced-motion: reduce) {
    .cmdk-overlay, .cmdk-panel { transition-duration: 0.01ms !important; }
  }
</style>
