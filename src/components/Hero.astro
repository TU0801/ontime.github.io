---
// Hero セクション: 筆文字 h1 + サブタイトル + CTA
// Phase 1-A で抽出
---

<section class="hero">
  <div class="hero-content">
    <p class="hero-eyebrow">Advanced Efficiency Solutions</p>
    <h1 class="gradient-text-hero hero-title" aria-label="残業を過去にする。">
      <span class="char-line">
        <span class="char" style="--i:0">残</span>
        <span class="char" style="--i:1">業</span>
        <span class="char" style="--i:2">を</span>
      </span>
      <br />
      <span class="char-line">
        <span class="char" style="--i:3">過</span>
        <span class="char" style="--i:4">去</span>
        <span class="char" style="--i:5">に</span>
        <span class="char" style="--i:6">す</span>
        <span class="char" style="--i:7">る</span>
        <span class="char" style="--i:8">。</span>
      </span>
    </h1>
    <h2 class="hero-subtitle">
      <span class="word" style="--i:0">Time</span>
      <span class="word" style="--i:1">is</span>
      <span class="word" style="--i:2">your</span>
      <span class="word" style="--i:3">asset.</span>
    </h2>
    <a href="/check" class="cta-btn">課題を診断する →</a>
  </div>
</section>
